# ─────────────────────────────────────────────────────────────
# CareerPilot — Backend environment variables
# Copy this file to `.env` and fill in your own values.
# NEVER commit your real `.env` file.
# ─────────────────────────────────────────────────────────────

# Google Gemini API key (https://aistudio.google.com/app/apikey).
# Optional: users can also bring their own key via the X-Gemini-Api-Key
# request header. If neither is set, AI calls will fail.
#
# DEMO TIP: set this and the UI will SKIP the "enter your API key" prompt
# entirely (frictionless live upload for judges) — the key never leaves the
# server and is never logged.
GEMINI_API_KEY=your-gemini-api-key-here

# Port the Express server listens on.
PORT=8080

# CORS allow-list — the origin of your frontend (no trailing slash).
ALLOWED_ORIGIN=http://localhost:5173

# Optional: override the Gemini model (defaults to gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash
